{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Greg's Feed",
  "version": "0.1.0",
  "identifier": "com.gregorycotton.gregs-feed",
  "build": {
    "frontendDist": "../templates"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Greg's Feed",
        "width": 900,
        "height": 1000,
        "minWidth": 640,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "News",
    "icon": [
      "../templates/favicon/favicon-32x32.png",
      "../templates/favicon/android-chrome-192x192.png",
      "../templates/favicon/android-chrome-512x512.png"
    ]
  }
}
